{
  "TickIntervalMs": 60,
  "Logging": {
    "Level": "Warn",
    "FileLevel": "Info"
    // "FilePath": "logs/vrcdmafish.log"
  },
  "Input": {
    "Type": "Mock",
    "ComPort": "Auto",
    "BaudRate": 115200,
    "NetIp": "192.168.2.188",
    "NetPort": 8006
  },
  "SignalSource": {
    "Type": "Dma",
    "ProcessName": "VRChat",
    "TargetObjectName": "FishingLogic"
    // 如果你有内部 Proxy 导出的目标组件 Il2CppClass 地址，优先填这个：
    // "TargetKlassAddress": "0x0"
    // 推荐改用 Il2CppInspectorPro 导出的 C# stub 自动解析字段偏移。
    // CSharpOutputPath 可以指向单个 types.cs，也可以指向导出目录。
    // "Il2CppInspectorPro": {
    //   "CSharpOutputPath": "C:\\dump\\types.cs",
    //   "TargetTypeName": "FishingLogic",
    //   "HookedFieldName": "_isHooked",
    //   "CatchCompletedFieldName": "_catchCompleted",
    //   "TensionFieldName": "_tension",
    //   "FishPositionFieldName": "_fishPosition",
    //   "BarCenterFieldName": "_barCenter",
    //   "BarHeightFieldName": "_barHeight"
    // }
    //
    // 如果你拿到的是“鱼位置 + 白条上下边界”，把上面的 BarCenter/BarHeight
    // 改成下面这组字段名即可：
    // "Il2CppInspectorPro": {
    //   "CSharpOutputPath": "C:\\dump\\types.cs",
    //   "TargetTypeName": "FishingLogic",
    //   "FishPositionFieldName": "_fishPosition",
    //   "BarTopFieldName": "_barTop",
    //   "BarBottomFieldName": "_barBottom"
    // }
    //
    // 手填偏移仍然可用，而且优先级高于 Il2CppInspectorPro 自动解析。
    // 如果你已经拿到新的 GOM 签名，也可以直接覆盖：
    // "GameObjectManagerPattern": "48 8B ... ??"
    // 或者一次提供多条候选签名，程序会逐条尝试并校验：
    // "GameObjectManagerPatterns": [
    //   "48 8B ... ??",
    //   "48 8D ... ??"
    // ]
    // 如果 Unity 特征扫描失效，可手动填写：
    // "GameObjectManagerAddress": "0x0",
    // 也支持模块相对写法，例如 "GameAssembly.dll+0x123456"
    // 这里既可以填真正的 GameObjectManager 基址，也可以填 active node / 候选 node 地址
    // "TargetObjectAddress": "0x0"
    //
    // Unity 2022.3.x Native 默认按 ActiveNodes 链表遍历：
    // GOM.activeObjectNodes = 0x28
    // ObjectNode.next = 0x08
    // ObjectNode.gameObject = 0x10
    // GameObject.componentArray = 0x30
    // GameObject.componentCount = 0x40
    // GameObject.namePtr = 0x60
    // ComponentArrayElement.stride = 0x10
    // ComponentArrayElement.componentPtr = 0x08
    // Component.klassPtr = 0x00
    // Component.gameObject = 0x10
    // Il2CppClass.namePtr = 0x10
    // Il2CppClass.namespazePtr = 0x18
    // Il2CppClass.parentPtr = 0x48
    // 如版本漂移，可覆盖这些布局偏移：
    // "GameObjectManagerActiveNodesOffset": "0x28",
    // "ObjectNodePreviousOffset": "0x00",
    // "ObjectNodeNextOffset": "0x08",
    // "ObjectNodeGameObjectOffset": "0x10",
    // "GameObjectComponentArrayOffset": "0x30",
    // "GameObjectComponentCountOffset": "0x40",
    // "GameObjectNamePointerOffset": "0x60",
    // "ComponentArrayElementStride": "0x10",
    // "ComponentArrayElementTypeInfoOffset": "0x00",
    // "ComponentArrayElementComponentPointerOffset": "0x08",
    // "ComponentKlassPointerOffset": "0x00",
    // "ComponentGameObjectOffset": "0x10",
    // "Il2CppClassNamePointerOffset": "0x10",
    // "Il2CppClassNamespacePointerOffset": "0x18",
    // "Il2CppClassParentPointerOffset": "0x48",
    // "MaxComponentCount": 1000,
    // "MaxStringLength": 64,
    // "MaxClassParentDepth": 8
    // 位置控制推荐直接走 DMA：
    // 方案 A：鱼位置 + 白条中心 + 白条高度
    // "FishPositionOffset": "0x50",
    // "BarCenterOffset": "0x54",
    // "BarHeightOffset": "0x58"
    //
    // 方案 B：鱼位置 + 白条上边界 + 白条下边界
    // "FishPositionOffset": "0x50",
    // "BarTopOffset": "0x54",
    // "BarBottomOffset": "0x58"
  },
  "Bot": {
    "CastDurationMs": 1200,
    "CooldownMs": 1500,
    "ReelTensionPauseThreshold": 0.8,
    "ReelTensionResumeThreshold": 0.55,
    "HookClickMs": 60,
    "ReelPulseMs": 80,
    "ReelHoldMinMs": 5,
    "ReelHoldMaxMs": 100,
    "ReelHoldGainMs": 60,
    "ReelVelocityDampingMs": 40,
    "ReelRestMs": 12,
    "PositionBaseHoldMs": 20,
    "PositionHoldGainMs": 55,
    "PositionVelocityDampingMs": 10.0,
    "PositionVelocitySmooth": 0.6,
    "PositionDeadZoneRatio": 0.3,
    "PositionPressMovesUp": true
  }
}
